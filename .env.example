# Path to the servers config file (list of POP3/IMAP accounts to drain).
# Copy etc/servers.toml.example to etc/servers.toml and fill in your accounts.
SERVERS_FILE=etc/servers.toml

# Path to the Google OAuth client credentials JSON from Google Cloud Console.
# Download from: APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CREDENTIALS_FILE=etc/credentials.json

# Path where the OAuth token will be cached between runs (local dev only).
GOOGLE_TOKEN_FILE=etc/token.json

# --- GCP deployment (Cloud Run) ---
# Set GOOGLE_TOKEN_SECRET to the Secret Manager secret name that holds the
# OAuth token JSON. When set, GOOGLE_TOKEN_FILE is ignored.
# The secret must already exist in Secret Manager (maildrain will add versions).
# GOOGLE_TOKEN_SECRET=maildrain-token
#
# GCP project ID — set automatically by Cloud Run, needed for Secret Manager.
# GOOGLE_CLOUD_PROJECT=my-gcp-project
